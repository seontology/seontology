###  https://w3id.org/seovoc/searchStage
:searchStage rdf:type owl:DatatypeProperty ;
             rdfs:domain :Intent ;
             rdfs:range xsd:string ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Funnel-stage classification (e.g., INFORMATIONAL, COMMERCIAL, TRANSACTIONAL)" ;
