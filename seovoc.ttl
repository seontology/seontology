@prefix : <https://w3id.org/seovoc/> .
@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix seo: <https://wordlift.io/ontology/SEO_Ontology#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix voaf: <http://purl.org/vocommons/voaf#> .
@prefix schema: <http://schema.org/> .
@base <https://w3id.org/seovoc/> .

<https://w3id.org/seovoc/> rdf:type owl:Ontology ;
                            dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                            dc:creator <https://wordlift.io> ;
                            dc:description "The SEO RDF vocabulary, described using W3C RDF Schema and the Web Ontology Language. The vocabulary builds on and refers to schema.org where appropriate."@en ;
                            dc:identifier "SEO Vocabulary" ;
                            dc:issued "2023-10-29T00:00:00Z" ;
                            dc:title "SEO Vocabulary" ;
                            :extends schema: .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/contributors
dc:contributors rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/creator
dc:creator rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/description
dc:description rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/identifier
dc:identifier rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/issued
dc:issued rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/elements/1.1/title
dc:title rdf:type owl:AnnotationProperty .


###  http://schema.org/license
schema:license rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  https://w3id.org/seovoc/extends
:extends rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  https://w3id.org/seovoc/about
:about rdf:type owl:ObjectProperty ;
       owl:inverseOf :isDescribedBy ;
       rdfs:domain :WebPage ;
       rdfs:range schema:Thing ;
       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
       dc:description "Each webpage has a main entity of type Thing: Person, Location, LocalBusiness etc." ;
       rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/anchorResource
:anchorResource rdf:type owl:ObjectProperty ;
                rdfs:domain :Link ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( owl:Thing
                                           :LinkGroup
                                         )
                           ] ;
                dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                dc:description "Points to an entity representing the linked content, useful for dereferencing in GraphQL" ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/classifiedByModel
:classifiedByModel rdf:type owl:ObjectProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :Intent
                                               :Sentiment
                                             )
                               ] ;
                   rdfs:range :Model ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Links an instance of Intent or Sentiment to the model that classified it" ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/describesPage
:describesPage rdf:type owl:ObjectProperty ;
               owl:inverseOf :hasSchemaMarkup ;
               rdfs:domain :Schema ;
               rdfs:range :WebPage ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Indicates the WebPage that is described by this schema markup block. Useful for linking structured data to content" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasAgent
:hasAgent rdf:type owl:ObjectProperty ;
          owl:inverseOf :hasPrompt ;
          rdfs:domain [ rdf:type owl:Class ;
                        owl:unionOf ( :Action
                                      :Prompt
                                    )
                      ] ;
          rdfs:range :Agent ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Links a Prompt, AnalyzeAction, or other SEO workflow entity to the Agent responsible for executing or generating it. It captures accountability and provenance within SEO workflows, identifying who or what performed the action, issued the instruction, or conducted the analysis." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasAnalysisTarget
:hasAnalysisTarget rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isAnalysisTargetOf ;
                   rdfs:domain :AnalyzeAction ;
                   rdfs:range [ rdf:type owl:Class ;
                                owl:unionOf ( :Chunk
                                              :WebPage
                                            )
                              ] ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Specifies the content unit (WebPage or Chunk) that is being analyzed by an AnalyzeAction. This property enables flexible analysis workflows that can operate at different granularities - from full webpage assessment to focused chunk-level evaluation. Essential for tracking which specific content segments are subject to automated quality analysis, performance evaluation, or SEO assessment within content optimization pipelines." ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasChildSegment
:hasChildSegment rdf:type owl:ObjectProperty ;
                 owl:inverseOf :hasParentSegment ;
                 rdfs:domain :DirectorySegment ;
                 rdfs:range :DirectorySegment ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "Inverse of hasParentSegment; points to subsegments" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasChunk
:hasChunk rdf:type owl:ObjectProperty ;
          owl:inverseOf :isChunkOf ;
          rdfs:domain :WebPage ;
          rdfs:range :Chunk ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Links a schema:WebPage to one or more Chunks representing segmented parts of the page" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasChunkQualityScore
:hasChunkQualityScore rdf:type owl:ObjectProperty ;
                      owl:inverseOf :isChunkQualityScoreOf ;
                      rdfs:domain :Chunk ;
                      rdfs:range :QualityScore ;
                      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                      dc:description "Establishes the relationship between a Chunk and its associated QualityScore assessment. This property enables quality evaluation at the content segment level, allowing for granular analysis of individual text portions within a webpage. Unlike page-level quality assessment, chunk-level scoring focuses on the coherence, relevance, and quality characteristics of specific content segments, supporting fine-grained content optimization and automated content analysis workflows." ;
                      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasDomain
:hasDomain rdf:type owl:ObjectProperty ;
           rdfs:domain :WebPage ;
           rdfs:range :Domain .


###  https://w3id.org/seovoc/hasEntityGap
:hasEntityGap rdf:type owl:ObjectProperty ;
              owl:inverseOf :isEntityGapOf ;
              rdfs:domain :Query ;
              rdfs:range :EntityGap ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Relates a query or context to the entity gaps identified in its content" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasExtractedChunk
:hasExtractedChunk rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isChunkOfExtraction ;
                   rdfs:domain :ExtractAction ;
                   rdfs:range :Chunk ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Establishes the relationship between an extraction operation and the content chunks it analyzes to retrieve specific information." ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasImage
:hasImage rdf:type owl:ObjectProperty ;
          owl:inverseOf :isImageOf ;
          rdfs:domain :WebPage ;
          rdfs:range :ImageObject ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasIntent
:hasIntent rdf:type owl:ObjectProperty ;
           owl:inverseOf :isIntentOf ;
           rdfs:domain :Chunk ,
                       :Query ;
           rdfs:range :Intent ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Links a content unit to its classified intent" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasLanguage
:hasLanguage rdf:type owl:ObjectProperty ;
             owl:inverseOf :isLanguageOfImage ;
             rdfs:domain :ImageObject ;
             rdfs:range :Language ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Indicates the language used in the generated or translated caption" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasLink
:hasLink rdf:type owl:ObjectProperty ;
         owl:inverseOf :isLinkOf ;
         rdfs:domain :LinkGroup ;
         rdfs:range :Link ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "Defines the relationship between a LinkGroup and the individual links it contains, helping to structure internal and external linking within a webpage" ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasLinkGroup
:hasLinkGroup rdf:type owl:ObjectProperty ;
              owl:inverseOf :isLinkGroupOf ;
              rdfs:domain :WebPage ;
              rdfs:range :LinkGroup ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Connects a WebPage to one or more LinkGroups that organize its internal links (e.g., navigation menus, sidebar sections, related content blocks). Enables grouping of links by purpose or position on the page" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasMainTopic
:hasMainTopic rdf:type owl:ObjectProperty ;
              owl:inverseOf :isMainTopicOf ;
              rdfs:domain :WebPage ;
              rdfs:range :Topic ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Connects the web page to its central semantic subject" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasModel
:hasModel rdf:type owl:ObjectProperty ;
          owl:inverseOf :isModelOfImage ;
          rdfs:domain :ImageObject ;
          rdfs:range :Model ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Connects an image to the model used to generate its caption" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPage
:hasPage rdf:type owl:ObjectProperty ;
         owl:inverseOf :isPageOf ;
         rdfs:domain :PageGroup ;
         rdfs:range :WebPage ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "The hasQuery property represents the relationship between a WebPage and the PageGroup class, designed to help identify in which group type, A/B testing-wise the group belongs to." ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPageInDomain
:hasPageInDomain rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isPartOfDomain ;
                 rdfs:domain :Domain ;
                 rdfs:range :WebPage ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "Domain contains this webpage" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasParentSegment
:hasParentSegment rdf:type owl:ObjectProperty ;
                  rdfs:domain :DirectorySegment ;
                  rdfs:range :DirectorySegment ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "Points to the parent directory in the hierarchy (e.g. /blog/seo/ → /blog/)" ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPathRoot
:hasPathRoot rdf:type owl:ObjectProperty ;
             owl:inverseOf :isRootOfWebpage ;
             rdfs:domain :WebPage ;
             rdfs:range :DirectorySegment ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Indicates which top-level segment a page belongs to" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPersona
:hasPersona rdf:type owl:ObjectProperty ;
            owl:inverseOf :isPersonaOf ;
            rdfs:domain :WebPage ;
            rdfs:range :Persona ;
            dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
            dc:description "Associates a webpage with a target persona, representing the intended audience based on characteristics such as interests, demographics, or behavior" ;
            rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPrimaryQuery
:hasPrimaryQuery rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isPrimaryQueryOf ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :Chunk ,
                             :WebPage ;
                 rdfs:range :Query ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "This object attribute helps us with the querying process of queries equal to certain text" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasPrompt
:hasPrompt rdf:type owl:ObjectProperty ;
           rdfs:domain :Agent ;
           rdfs:range :Prompt ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ,
                           "hasPrompt links an entity (such as a Task, Agent, or Query) to a specific Prompt that guides or constrains the behavior of an Agent. It expresses the dependency on a natural language instruction or template used to initiate or shape an AI-driven action." ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasQualityScore
:hasQualityScore rdf:type owl:ObjectProperty ;
                 owl:inverseOf :isQualityScoreOf ;
                 rdfs:domain :WebPage ;
                 rdfs:range :QualityScore ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "Links the page to its evaluation result" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasQuery
:hasQuery rdf:type owl:ObjectProperty ;
          owl:inverseOf :isQueryOf ;
          rdfs:domain :WebPage ;
          rdfs:range :Query ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "The hasQuery property represents the relationship between a WebPage and the Query that leads users to that page. It indicates that the WebPage is relevant or has been optimized for the specified Query. This relationship is crucial for understanding SEO dynamics, as it reflects the connection between user search behavior and web content." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasSchemaMarkup
:hasSchemaMarkup rdf:type owl:ObjectProperty ;
                 rdfs:domain :WebPage ;
                 rdfs:range :Schema ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "The usesSchema property describes the relationship between a WebPage and the Schema it employs. The Schema class represents structured data, such as JSON-LD, Microdata, or RDFa, that is embedded in the webpage to provide search engines and other tools with enhanced information about the content." ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasSegmentPage
:hasSegmentPage rdf:type owl:ObjectProperty ;
                rdfs:domain :DirectorySegment ;
                rdfs:range :WebPage ;
                dc:description "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ,
                               "Segment contains this webpage" ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasSentiment
:hasSentiment rdf:type owl:ObjectProperty ;
              owl:inverseOf :isSentimentOf ;
              rdfs:domain :Chunk ,
                          :Query ;
              rdfs:range :Sentiment ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Links a content unit to its classified sentiment" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/hasURL
:hasURL rdf:type owl:ObjectProperty ;
        owl:inverseOf :isURLOf ;
        rdf:type owl:FunctionalProperty ,
                 owl:InverseFunctionalProperty ;
        rdfs:domain :WebPage ;
        rdfs:range :URL ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "The hasURL property establishes a unique and reciprocal relationship between a WebPage and its corresponding URL. It asserts that each WebPage is identified by exactly one URL, and conversely, each URL uniquely identifies one WebPage. As both a functional and inverse functional property, hasURL ensures that this link is both unique and bidirectional, which is critical for accurately representing the identity and accessibility of web content" ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/influencedByQuery
:influencedByQuery rdf:type owl:ObjectProperty ;
                   rdfs:domain :AnchorText ;
                   rdfs:range :Query ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "The influencedByQuery property defines the relationship between AnchorText and the Query that may shape or determine the choice of that anchor text. It highlights how specific search queries can influence the wording and selection of anchor texts within a WebPage, reflecting SEO strategies aimed at optimizing link relevance and search engine visibility. This property is vital for understanding the interplay between user search behavior and content creation, particularly in the context of link building and on-page SEO" ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isAnalysisTargetOf
:isAnalysisTargetOf rdf:type owl:ObjectProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( :Chunk
                                                :WebPage
                                              )
                                ] ;
                    rdfs:range :AnalyzeAction ;
                    dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                    dc:description "Inverse of hasAnalysisTarget. Links content units (WebPage or Chunk) back to the AnalyzeAction instances that examine them, enabling reverse navigation from content to its analysis activities and supporting queries that identify all analysis operations performed on specific content segments." ;
                    rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isChunkOf
:isChunkOf rdf:type owl:ObjectProperty ;
           rdfs:domain :Chunk ;
           rdfs:range :WebPage ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Links a Chunk to the parent WebPage it belongs to, defining the document structure" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isChunkOfExtraction
:isChunkOfExtraction rdf:type owl:ObjectProperty ;
                     rdfs:domain :Chunk ;
                     rdfs:range :ExtractAction ;
                     dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                     dc:description "Enables navigation from content chunks to all extraction actions that have analyzed them for information retrieval." ;
                     rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isChunkQualityScoreOf
:isChunkQualityScoreOf rdf:type owl:ObjectProperty ;
                       rdfs:domain :QualityScore ;
                       rdfs:range :Chunk ;
                       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                       dc:description "Inverse property of hasChunkQualityScore that links a QualityScore instance back to the specific Chunk it evaluates. This relationship enables navigation from quality assessment results to their corresponding content segments, facilitating analysis workflows that need to identify which chunk produced particular quality metrics. Essential for content optimization systems that require traceability between quality scores and their source content segments within automated SEO and content analysis pipelines." ;
                       rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isContainedInSegment
:isContainedInSegment rdf:type owl:ObjectProperty ;
                      rdfs:domain :WebPage ;
                      rdfs:range :DirectorySegment ;
                      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                      dc:description "Indicates the segment that contains a web page" ;
                      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isDescribedBy
:isDescribedBy rdf:type owl:ObjectProperty ;
               rdfs:domain owl:Thing ;
               rdfs:range :WebPage ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Inverse of about. Points from an entity to the page that describes it" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isEntityGapOf
:isEntityGapOf rdf:type owl:ObjectProperty ;
               rdfs:domain :EntityGap ;
               rdfs:range :Query ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Links an entity gap to the query or analysis context it belongs to" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isImageOf
:isImageOf rdf:type owl:ObjectProperty ;
           rdfs:domain :ImageObject ;
           rdfs:range :WebPage ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Inverse of hasImage; links an image back to its source page" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isIntentOf
:isIntentOf rdf:type owl:ObjectProperty ;
            rdfs:domain :Intent ;
            rdfs:range [ rdf:type owl:Class ;
                         owl:unionOf ( :Chunk
                                       :Query
                                       :WebPage
                                     )
                       ] ;
            dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
            dc:description "Inverse: Links intent to the content units it classifies" ;
            rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isLanguageOfImage
:isLanguageOfImage rdf:type owl:ObjectProperty ;
                   rdfs:domain :Language ;
                   rdfs:range :ImageObject ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Inverse of hasLanguage; returns images captioned in the given language" ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isLinkGroupOf
:isLinkGroupOf rdf:type owl:ObjectProperty ;
               rdfs:domain :LinkGroup ;
               rdfs:range :WebPage ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Defines the relationship between a LinkGroup and the WebPage it belongs to, helping structure internal linking and improve content organization" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isLinkOf
:isLinkOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Link ;
          rdfs:range :WebPage ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Inverse property of seovoc:hasLink, linking a link back to its parent LinkGroup" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isMainTopicOf
:isMainTopicOf rdf:type owl:ObjectProperty ;
               rdfs:domain :Topic ;
               rdfs:range :WebPage ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Inverse of hasMainTopic; links a topic to the pages where it is featured" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isModelOfImage
:isModelOfImage rdf:type owl:ObjectProperty ;
                rdfs:domain :Model ;
                rdfs:range :ImageObject ;
                dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                dc:description "Inverse of hasModel; identifies images a model has been used for" ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isPageOf
:isPageOf rdf:type owl:ObjectProperty ;
          rdfs:domain :WebPage ;
          rdfs:range :PageGroup ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Inverse of hasPage. Indicates which page group a web page belongs to" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isPartOfDirectorySegment
:isPartOfDirectorySegment rdf:type owl:ObjectProperty ;
                          rdfs:domain :WebPage ;
                          rdfs:range :DirectorySegment ;
                          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                          dc:description "Indicates the directory segment of the page’s URL" ;
                          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isPartOfDomain
:isPartOfDomain rdf:type owl:ObjectProperty ;
                rdfs:domain :WebPage ;
                rdfs:range :Domain ;
                dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                dc:description "Indicates the domain or subdomain to which the page belongs" ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isPersonaOf
:isPersonaOf rdf:type owl:ObjectProperty ;
             rdfs:domain :Persona ;
             rdfs:range :WebPage ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Inverse of hasPersona. Links a persona to the page it is associated with" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isPrimaryQueryOf
:isPrimaryQueryOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :Query ;
                  rdfs:range :WebPage ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "Defines the relationship between a search query (seovoc:Query) and the webpage (seovoc:WebPage) for which it serves as the main or most relevant query" ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isQualityScoreOf
:isQualityScoreOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :QualityScore ;
                  rdfs:range :WebPage ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "Inverse of seovoc:hasQualityScore. Links a quality score instance back to the web page it evaluates" ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isQueryOf
:isQueryOf rdf:type owl:ObjectProperty ;
           rdfs:domain :Query ;
           rdfs:range :WebPage ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Inverse of hasQuery. Indicates which web page a query relates to" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isRootOfWebpage
:isRootOfWebpage rdf:type owl:ObjectProperty ;
                 rdfs:domain :DirectorySegment ;
                 rdfs:range :WebPage ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "Indicates a root segment responsible for a page" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isSentimentOf
:isSentimentOf rdf:type owl:ObjectProperty ;
               rdfs:domain :Sentiment ;
               rdfs:range [ rdf:type owl:Class ;
                            owl:unionOf ( :Chunk
                                          :Query
                                          :WebPage
                                        )
                          ] ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Relates the sentiment to the piece of content to which the sentiment applies" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isURLOf
:isURLOf rdf:type owl:ObjectProperty ;
         rdfs:domain :URL ;
         rdfs:range :WebPage ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "Inverse of hasURL. Connects a URL to the web page it represents" ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/isUsedByAgent
:isUsedByAgent rdf:type owl:ObjectProperty ;
               owl:inverseOf :usesTool ;
               rdfs:domain :Tool ;
               rdfs:range :Agent ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Inverse of usesTool. Links a Tool back to the Agent(s) that utilize it." ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/issuedBy
:issuedBy rdf:type owl:ObjectProperty ;
          rdfs:domain :Prompt ;
          rdfs:range :Employee ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "issuedBy links a Prompt to the Employee who authored, formulated, or issued it. It captures the origin and authorship of instructional input, supporting traceability, collaboration, and evaluation in SEO workflows." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/link
:link rdf:type owl:ObjectProperty ;
      rdfs:domain :WebPage ;
      rdfs:range :Link ;
      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
      dc:description "The link property represents the relationship between a WebPage and the various Links contained within it. Each instance of the Link class corresponds to a hyperlink found on the WebPage, capturing both internal and external connections. This property is essential for modeling the structure of a webpage, understanding the flow of traffic between pages, and analyzing link-based SEO strategies, as it reflects the network of connections that can influence search engine rankings and user navigation." ;
      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/mentions
:mentions rdf:type owl:ObjectProperty ;
          rdfs:domain :WebPage ;
          rdfs:range schema:Thing ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Each webpage has an entity of type Thing: Person, Location, LocalBusiness etc." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/usesTool
:usesTool rdf:type owl:ObjectProperty ;
          rdfs:domain :Agent ;
          rdfs:range :Tool ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Links an Agent to the Tool(s) they employ to perform analysis actions. This relationship captures the instrumental means by which agents execute their analytical tasks." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


#################################################################
#    Data properties
#################################################################

###  http://www.w3.org/2002/07/owl#topDataProperty
owl:topDataProperty rdfs:domain :DirectorySegment ;
                    rdfs:range xsd:string ;
                    dc:description "Establishes the relationship between a Chunk and its associated QualityScore assessment. This property enables quality evaluation at the content segment level, allowing for granular analysis of individual text portions within a webpage. Unlike page-level quality assessment, chunk-level scoring focuses on the coherence, relevance, and quality characteristics of specific content segments, supporting fine-grained content optimization and automated content analysis workflows." .


###  https://w3id.org/seovoc/ageRange
:ageRange rdf:type owl:DatatypeProperty ;
          rdfs:domain :Persona ;
          rdfs:range xsd:string ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Represents the age range of a persona, typically expressed as a string (e.g., '18-25'). This property helps categorize personas by their approximate age groups for tailored strategies or content." ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/agentID
:agentID rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :identifier ;
         rdfs:domain :Agent ;
         rdfs:range xsd:int ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "Unique identifier for the agent" ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/agentType
:agentType rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :type ;
           rdfs:domain :Agent ;
           rdfs:range xsd:string ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Indicates the type of agent (human, AI, bot, system...)" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/agentVersion
:agentVersion rdf:type owl:DatatypeProperty ;
              rdfs:domain :Agent ;
              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Indicates the version number for the agent" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/aiGeneratedCaption
:aiGeneratedCaption rdf:type owl:DatatypeProperty ;
                    rdfs:domain :ImageObject ;
                    rdfs:range xsd:string ;
                    dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                    dc:description "Caption generated by an AI model describing the image content" ;
                    rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/aiGeneratedFileName
:aiGeneratedFileName rdf:type owl:DatatypeProperty ;
                     rdfs:domain :ImageObject ;
                     rdfs:range xsd:string ;
                     dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                     dc:description "SEO-optimized file name generated by an AI mode" ;
                     rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/analysisMethod
:analysisMethod rdf:type owl:DatatypeProperty ;
                rdfs:domain :AnalyzeAction ;
                rdfs:range xsd:string ;
                dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                dc:description "Method used for performing the analysis. Examples: 'automated' for tool-based analysis without human intervention, 'manual' for human-conducted evaluation, 'hybrid' for combined automated and manual review, 'ai-based' for LLM or machine learning analysis, 'tool-based' for analysis using specific software tools like Lighthouse or PageSpeed Insight." ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/analysisScope
:analysisScope rdf:type owl:DatatypeProperty ;
               rdfs:domain :AnalyzeAction ;
               rdfs:range xsd:string ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Scope or granularity of the analysis. Examples: 'page' for single webpage analysis, 'site' for entire website evaluation, 'domain' for domain-wide assessment including subdomains, 'element' for specific HTML elements or components, 'resource' for individual files like CSS or JavaScript, 'chunk' for content segments or text blocks within a page." ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/analysisType
:analysisType rdf:type owl:DatatypeProperty ;
              rdfs:domain :AnalyzeAction ;
              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Type of analysis to perform. Examples: 'content' for readability and quality assessment, 'performance' for speed and Core Web Vitals, 'accessibility' for WCAG compliance, 'security' for HTTPS and headers, 'technical-seo' for meta tags and markup, 'usability' for user experience factors, 'mobile' for mobile-specific analysis, 'core-web-vitals' for LCP/FID/CLS metrics." ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/anchorValue
:anchorValue rdf:type owl:DatatypeProperty ;
             rdfs:domain :AnchorText ;
             rdfs:range xsd:string ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "The text of the anchor tied to the link itself" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


