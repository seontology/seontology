:linkgroupID rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :identifier ;
             rdfs:domain :LinkGroup ;
             rdfs:range xsd:int ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
