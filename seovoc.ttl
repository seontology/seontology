          rdfs:range xsd:anyURI ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Web-accessible URI pointing to the model, documentation, or registry entry" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/name
:name rdf:type owl:DatatypeProperty ;
      rdfs:domain owl:Thing ;
      rdfs:range xsd:string ;
      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
      dc:description "The human-readable name of the LinkGroup, typically reflecting its function or placement on a webpage (e.g., 'Footer Links', 'Sidebar Menu', 'Main Navigation')" ;
      rdfs:isDefinedBy <https://w3id.org/seovoc/> ;
      skos:exactMatch <https://schema.org/name> .


###  https://w3id.org/seovoc/noFollow
:noFollow rdf:type owl:DatatypeProperty ;
          rdfs:domain :Link ;
          rdfs:range xsd:boolean ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "A metric to define whether the nofollow is in place (True for Yes and False for No)" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/occurrences
:occurrences rdf:type owl:DatatypeProperty ;
             rdfs:domain :EntityGap ;
             rdfs:range xsd:int ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "An integer indicating how many times the missing entity appears in the analyzed data" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/pageGroupName
:pageGroupName rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :name ;
               rdfs:domain :PageGroup ;
               rdfs:range xsd:string ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Indicates the name of the group in which the page belongs, A , B, C (control A, control B, test A, test ...B)" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/performedAt
:performedAt rdf:type owl:DatatypeProperty ;
             rdfs:domain :Action ;
             rdfs:range xsd:dateTime ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Timestamp indicating when the action was executed, enabling temporal tracking and audit trails within SEO workflows." ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/position
:position rdf:type owl:DatatypeProperty ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "The position of an item in a series or sequence of items" ;
          skos:exactMatch <https://schema.org/position> .


###  https://w3id.org/seovoc/preferredDevice
:preferredDevice rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Persona ;
                 rdfs:range xsd:string ;
                 dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                 dc:description "Represents the device type a persona most commonly uses to access information or services. Examples include 'mobile', 'desktop', 'tablet', or 'smart speaker'. This property helps in tailoring content and strategies to the persona's preferred platform" ;
                 rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/priorityScore
:priorityScore rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :score ;
               rdfs:domain :WebPage ;
               rdfs:range xsd:float ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Used in automated sitemap generation and crawl scheduling to prioritize the discovery and indexing of pages that are central to the website's architecture or frequently updated" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/promptDate
:promptDate rdf:type owl:DatatypeProperty ;
            rdfs:subPropertyOf :date ;
            rdfs:domain :Prompt ;
            rdfs:range xsd:dateTime ;
            dc:description "A date when the prompt was put into the system" ;
            rdfs:isDefinedBy <https://w3id.org/seovoc/> ,
                             "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" .


###  https://w3id.org/seovoc/publishingDate
:publishingDate rdf:type owl:DatatypeProperty ;
                rdfs:subPropertyOf :date ;
                rdfs:domain :WebPage ;
                rdfs:range xsd:dateTime ;
                dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                dc:description "The date where the webpage was published" ;
                rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/queryCategory
:queryCategory rdf:type owl:DatatypeProperty ;
               rdfs:domain :Query ;
               rdfs:range [ rdf:type rdfs:Datatype ;
                            owl:oneOf [ rdf:type rdf:List ;
                                        rdf:first "Advice" ;
                                        rdf:rest [ rdf:type rdf:List ;
                                                   rdf:first "Explanations" ;
                                                   rdf:rest [ rdf:type rdf:List ;
                                                              rdf:first "Facts" ;
                                                              rdf:rest [ rdf:type rdf:List ;
                                                                         rdf:first "Planning" ;
                                                                         rdf:rest rdf:nil
                                                                       ]
                                                            ]
                                                 ]
                                      ]
                          ] ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description """Represents the broader category of a user's information-seeking query. This property classifies queries into four key categories based on their intent and expected outcome: 
        - Advice: Queries that seek recommendations, suggestions, or guidance for decision-making. 
        - Explanations: Queries aimed at understanding concepts, reasoning, or detailed clarifications.
        - Facts: Queries that request verifiable and objective pieces of information.
        - Planning: Queries focused on structuring activities, workflows, or determining sequential steps to achieve a goal.
These categories help in organizing user search behaviors and improving query understanding.""" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/queryDateCreated
:queryDateCreated rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :date ;
                  rdfs:domain :Query ;
                  rdfs:range xsd:dateTime ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "The date/time this keyword analytics data has been extracted and imported in the KG." ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/queryType
:queryType rdf:type owl:DatatypeProperty ;
           rdfs:subPropertyOf :type ;
           rdfs:domain :Query ;
           rdfs:range [ rdf:type rdfs:Datatype ;
                        owl:oneOf [ rdf:type rdf:List ;
                                    rdf:first "Analytical" ;
                                    rdf:rest [ rdf:type rdf:List ;
                                               rdf:first "Causal" ;
                                               rdf:rest [ rdf:type rdf:List ;
                                                          rdf:first "Commonsense" ;
                                                          rdf:rest [ rdf:type rdf:List ;
                                                                     rdf:first "Cultural" ;
                                                                     rdf:rest [ rdf:type rdf:List ;
                                                                                rdf:first "Dynamic" ;
                                                                                rdf:rest [ rdf:type rdf:List ;
                                                                                           rdf:first "Exploratory" ;
                                                                                           rdf:rest [ rdf:type rdf:List ;
                                                                                                      rdf:first "Instructive" ;
                                                                                                      rdf:rest [ rdf:type rdf:List ;
                                                                                                                 rdf:first "Lifestyle" ;
                                                                                                                 rdf:rest [ rdf:type rdf:List ;
                                                                                                                            rdf:first "Long-tail" ;
                                                                                                                            rdf:rest [ rdf:type rdf:List ;
                                                                                                                                       rdf:first "Multi-hop" ;
                                                                                                                                       rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                  rdf:first "Philosophical" ;
                                                                                                                                                  rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                             rdf:first "Popular" ;
                                                                                                                                                             rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                                        rdf:first "Recommendation" ;
                                                                                                                                                                        rdf:rest [ rdf:type rdf:List ;
                                                                                                                                                                                   rdf:first "Spatio-temporal" ;
                                                                                                                                                                                   rdf:rest rdf:nil
                                                                                                                                                                                 ]
                                                                                                                                                                      ]
                                                                                                                                                           ]
                                                                                                                                                ]
                                                                                                                                     ]
                                                                                                                          ]
                                                                                                               ]
                                                                                                    ]
                                                                                         ]
                                                                              ]
                                                                   ]
                                                        ]
                                             ]
                                  ]
                      ] ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Specifies the type of query a user is performing, which must belong to a predefined set of query categories. These categories include: Popular, Long-tail, Dynamic, Multi-hop, Analytical, Commonsense, Causal, Exploratory, Instructive, Recommendation, Spatio-temporal, Lifestyle, Cultural, and Philosophical." ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/readabilityGradeLevel
:readabilityGradeLevel rdf:type owl:DatatypeProperty ;
                       rdfs:domain :WebPage ;
                       rdfs:range xsd:string ;
                       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                       dc:description "An ordinal estimate (e.g., U.S. school grade level)" ;
                       rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/readabilityScore
:readabilityScore rdf:type owl:DatatypeProperty ;
                  rdfs:subPropertyOf :score ;
                  rdfs:domain :QualityScore ;
                  rdfs:range xsd:float ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "Readability score for the webpage" ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/role
:role rdf:type owl:DatatypeProperty ;
      rdfs:domain :Persona ;
      rdfs:range xsd:string ;
      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
      dc:description "A specific function, position, or responsibility associated with a persona within a given context. This class defines how a persona interacts with a system, organization, or content, influencing their goals and actions." ;
      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


