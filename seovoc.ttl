:Domain rdf:type owl:Class ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "A domain or subdomain (e.g., example.com, blog.example.com)" ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Employee
:Employee rdf:type owl:Class ;
          rdfs:subClassOf :Person ;
