                   rdfs:domain :WebPage ;
                   rdfs:range xsd:int ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Number of other pages that link to this page (link popularity signal)" ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/intent
:intent rdf:type owl:DatatypeProperty ;
        rdfs:domain :WebPage ;
        rdfs:range xsd:string ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "Intent is done on a page level, so it will be added as a data property to the Page class" ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/internalLinkCount
:internalLinkCount rdf:type owl:DatatypeProperty ;
                   rdfs:domain :WebPage ;
                   rdfs:range xsd:int ;
                   dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                   dc:description "Number of links that point to the same domain as the current page" ;
                   rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/internalPageRank
:internalPageRank rdf:type owl:DatatypeProperty ;
                  rdfs:domain :WebPage ;
                  rdfs:range xsd:int ;
                  dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                  dc:description "PageRank score computed based on internal link structure" ;
                  rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/keywordOptimizationScore
:keywordOptimizationScore rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf :score ;
                          rdfs:domain :QualityScore ;
                          rdfs:range xsd:float ;
                          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
                          dc:description "Keyword usage and distribution score" ;
                          rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/keywordType
:keywordType rdf:type owl:DatatypeProperty ;
             rdfs:subPropertyOf :type ;
             rdfs:domain :Query ;
             rdfs:range xsd:string ;
             dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
             dc:description "Primary and secondary keyword modeling are expressed through the use of the data property keywordType" ;
             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/keywords
:keywords rdf:type owl:DatatypeProperty ;
          rdfs:domain :Link ;
          rdfs:range xsd:string ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "A list of keywords associated with the specific link, aiding semantic classification" ;
          rdfs:isDefinedBy <https://w3id.org/seovoc/> ;
          skos:exactMatch <https://schema.org/keywords> .


###  https://w3id.org/seovoc/label
