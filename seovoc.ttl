###  https://w3id.org/seovoc/EntityGap
:EntityGap rdf:type owl:Class ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "Represents a relevant but missing entity that should be added to content to enhance semantic coverage and SEO performance" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/ExtractAction
:ExtractAction rdf:type owl:Class ;
               rdfs:subClassOf :Action ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "Represents systematic extraction of structured or unstructured information from web content, including entity extraction, fact retrieval, data mining, and relationship identification. Distinct from summarization by focusing on specific information retrieval rather than content condensation." ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/ImageObject
:ImageObject rdf:type owl:Class ;
             skos:exactMatch <https://schema.org/ImageObject> .


###  https://w3id.org/seovoc/Intent
:Intent rdf:type owl:Class ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "A reusable conceptual entity representing the purpose of a query or content chunk" ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Language
:Language rdf:type owl:Class ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
          dc:description "Natural languages such as Spanish, Tamil, Hindi, English, etc" ;
          skos:exactMatch <https://schema.org/Language> .


###  https://w3id.org/seovoc/Link
:Link rdf:type owl:Class ;
      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
      dc:description "A class representing a hyperlink found on a webpage. This class captures the attributes of a link and its type, such as whether the link is internal (pointing to the same domain) or external (pointing to a different domain). The Link class is crucial for understanding the structure and navigation of a website, as well as for analyzing the relationships between different web resources in the context of SEO and web development." ;
      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/LinkGroup
:LinkGroup rdf:type owl:Class ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "A collection of related links within a webpage, typically grouped by placement or function, such as navigation menus, footers, or sidebars. It helps structure internal linking and improves discoverability." ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Model
:Model rdf:type owl:Class ;
       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
       dc:description "A generic ML model class for provenance traceabilit" ;
       rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/PageGroup
:PageGroup rdf:type owl:Class ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "A class representing in which A/B testing group does the page belong: control A, control B, test A, test B and so on." ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Person
:Person rdf:type owl:Class ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:identifier <https://w3id.org/seovoc/> ;
        skos:exactMatch schema:Person .


###  https://w3id.org/seovoc/Persona
:Persona rdf:type owl:Class ;
         rdfs:subClassOf :Person ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "A representation of a specific audience or user group defined by key characteristics, including their role, brand association, age range, gender, location, problems they aim to solve, and preferred devices. This class is used to tailor content or strategies to meet the needs and expectations of these target personas." ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Prompt
:Prompt rdf:type owl:Class ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "Represents a structured natural language input used to guide AI models in generating or transforming SEO-relevant content. It serves as a semantic instruction or query that elicits specific types of responses from generative or analytical AI systems, including but not limited to content generation, classification, rewriting, summarization, and entity extraction." ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/QualityScore
:QualityScore rdf:type owl:Class ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Represents an overall content quality evaluation" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Query
:Query rdf:type owl:Class ;
       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
       dc:description "A class representing a search query. Instances of this class encapsulate the parameters, conditions, and terms submitted to a search engine by users or systems. This class is fundamental to modeling and analyzing search behavior, including keyword selection, query intent, and search patterns in the context of SEO."@en ;
       rdfs:isDefinedBy <https://w3id.org/seovoc/> ;
       rdfs:label "Query"@en .


###  https://w3id.org/seovoc/Schema
:Schema rdf:type owl:Class ;
        dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
        dc:description "This class represents schema markup, a form of structured data that defines the semantic relationships between entities on a webpage. Schema markup is used to enhance the understanding of web content by search engines and other applications, facilitating better indexing, richer search results, and improved interoperability across different systems. This class provides a framework for describing the types, properties, and relationships that constitute schema markup, enabling consistent and meaningful representation of web content." ;
        rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Sentiment
:Sentiment rdf:type owl:Class ;
           dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
           dc:description "A conceptual entity representing the emotional polarity (e.g., positive, negative) of a query or content chunk" ;
           rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Tool
:Tool rdf:type owl:Class ;
      dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
      dc:description "A software application, platform, or instrument used to perform SEO analysis, content evaluation, or web assessment. Tools are utilized by Agents to execute specific analysis tasks and generate measurable outputs." ;
      rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/Topic
:Topic rdf:type owl:Class ;
       dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
       dc:description "A dedicated class for modeling the subject or main theme of a web page or content segment. It can represent an entity, theme, or abstract concept the content is centered on" ;
       rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/URL
:URL rdf:type owl:Class ;
     dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
     dc:description "This class represents a unique URL that identifies a specific webpage. It is intended to serve as a stable and unambiguous reference to web content, ensuring consistent access to the webpage across various systems and applications. The URL should be a valid and well-formed HTTP or HTTPS address, uniquely pointing to a resource on the World Wide Web. NOT equivalent to schema.org's URL." ;
     rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/WebPage
:WebPage rdf:type owl:Class ;
         rdfs:subClassOf owl:Thing ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "A web page. Every web page is implicitly assumed to be declared to be of type WebPage, so the various properties about that webpage, such as breadcrumb may be used. We recommend explicit declaration if these properties are specified, but if they are found outside of an itemscope, they will be assumed to be about the page."@en ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> ;
         rdfs:label "WebPage"@en ;
         skos:exactMatch schema:WebPage .


