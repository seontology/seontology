###  https://w3id.org/seovoc/chunkID
:chunkID rdf:type owl:DatatypeProperty ;
         rdfs:subPropertyOf :identifier ;
         rdfs:domain :Chunk ;
         rdfs:range xsd:int ;
         dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
         dc:description "A unique string identifier for distinguishing individual resources, such as chunks" ;
         rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/chunkPosition
:chunkPosition rdf:type owl:DatatypeProperty ;
               rdfs:subPropertyOf :position ;
               rdfs:domain :Chunk ;
               rdfs:range xsd:int ;
               dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
               dc:description "The order of the chunk on the webpage, starting from 1 for the first chunk. Useful for reconstructing the document from its parts or presenting chunks in context" ;
               rdfs:isDefinedBy <https://w3id.org/seovoc/> ;
               skos:exactMatch <https://schema.org/position> .


###  https://w3id.org/seovoc/chunkSetName
:chunkSetName rdf:type owl:DatatypeProperty ;
              rdfs:domain :Chunk ;
              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "The name of the set of chunks (e.g., \"Introduction\", \"Body\", \"Summary\"). Useful for organizing chunks into meaningful groups" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/chunkStrategy
:chunkStrategy rdf:type owl:DatatypeProperty ;
