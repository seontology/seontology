             rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/locationName
:locationName rdf:type owl:DatatypeProperty ;
              rdfs:domain :EntityGap ;
              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Indicates where in the content or source the entity gap was detected" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/markdownText
:markdownText rdf:type owl:DatatypeProperty ;
              rdfs:subPropertyOf :text ;
              rdfs:domain :WebPage ;
              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Represents a Markdown-formatted version of a webpage’s content, specifically structured for Large Language Model (LLM) processing, meant for efficient tokenization and retrieval-augmented generation (RAG) in AI applications" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/menu
