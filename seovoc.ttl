              rdfs:range xsd:string ;
              dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
              dc:description "Location of the link within the layout (e.g., nav, header, footer, body)" ;
              rdfs:isDefinedBy <https://w3id.org/seovoc/> .


###  https://w3id.org/seovoc/linkText
:linkText rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :text ;
          rdfs:domain :Link ;
          rdfs:range xsd:string ;
          dc:contributors "Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik" ;
