        <dc:description>Indicates the group type in which the page belongs, e.g. control or test.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h1 -->

