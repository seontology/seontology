        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Subheading (&lt;h2&gt;); repeatable for clustered content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h3 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/h3">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/heading"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Optional tertiary heading (&lt;h3&gt;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h4 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/h4">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/heading"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Optional heading level 4 (&lt;h4&gt;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h5 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/h5">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/heading"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Optional heading level 5 (&lt;h5&gt;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h6 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/h6">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/heading"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Optional heading level 6 (&lt;h6&gt;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/heading -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/heading">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents any on-page heading element, from &lt;h1&gt; to &lt;h6&gt;, allowing generalized access to a page’s structural content hierarchy</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/identifier -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/identifier">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A general-purpose string or URI identifier for any resource in the ontology</dc:description>
        <skos:exactMatch rdf:resource="https://schema.org/identifier"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/importHash -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/importHash">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A hash of the data to understand whether it changed</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/importID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/importID">
