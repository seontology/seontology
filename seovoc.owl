<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/seovoc/"
     xml:base="https://w3id.org/seovoc/"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:seo="https://wordlift.io/ontology/SEO_Ontology#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:voaf="http://purl.org/vocommons/voaf#"
     xmlns:schema="http://schema.org/"
     xmlns:seovoc="https://w3id.org/seovoc/">
    <owl:Ontology rdf:about="https://w3id.org/seovoc/">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:creator rdf:resource="https://wordlift.io"/>
        <dc:description xml:lang="en">The SEO RDF vocabulary, described using W3C RDF Schema and the Web Ontology Language. The vocabulary builds on and refers to schema.org where appropriate.</dc:description>
        <dc:identifier>SEO Vocabulary</dc:identifier>
        <dc:issued>2023-10-29T00:00:00Z</dc:issued>
        <dc:title>SEO Vocabulary</dc:title>
        <extends rdf:resource="http://schema.org/"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/elements/1.1/contributors -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/contributors"/>
    


    <!-- http://purl.org/dc/elements/1.1/creator -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/creator"/>
    


    <!-- http://purl.org/dc/elements/1.1/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/description"/>
    


    <!-- http://purl.org/dc/elements/1.1/identifier -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/identifier"/>
    


    <!-- http://purl.org/dc/elements/1.1/issued -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/issued"/>
    


    <!-- http://purl.org/dc/elements/1.1/title -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://schema.org/license -->

    <owl:AnnotationProperty rdf:about="http://schema.org/license"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- https://w3id.org/seovoc/extends -->

    <owl:AnnotationProperty rdf:about="https://w3id.org/seovoc/extends"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://w3id.org/seovoc/about -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/about">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isDescribedBy"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://schema.org/Thing"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Each webpage has a main entity of type Thing: Person, Location, LocalBusiness etc.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/anchorResource -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/anchorResource">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/LinkGroup"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Points to an entity representing the linked content, useful for dereferencing in GraphQL</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/classifiedByModel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/classifiedByModel">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Intent"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Sentiment"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Model"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links an instance of Intent or Sentiment to the model that classified it</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/describesPage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/describesPage">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/hasSchemaMarkup"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Schema"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the WebPage that is described by this schema markup block. Useful for linking structured data to content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasAgent">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/hasPrompt"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Action"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Prompt"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Agent"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a Prompt, AnalyzeAction, or other SEO workflow entity to the Agent responsible for executing or generating it. It captures accountability and provenance within SEO workflows, identifying who or what performed the action, issued the instruction, or conducted the analysis.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasAnalysisTarget -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasAnalysisTarget">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isAnalysisTargetOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnalyzeAction"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Chunk"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/WebPage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Specifies the content unit (WebPage or Chunk) that is being analyzed by an AnalyzeAction. This property enables flexible analysis workflows that can operate at different granularities - from full webpage assessment to focused chunk-level evaluation. Essential for tracking which specific content segments are subject to automated quality analysis, performance evaluation, or SEO assessment within content optimization pipelines.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasChildSegment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasChildSegment">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/hasParentSegment"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasParentSegment; points to subsegments</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasChunk -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasChunk">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isChunkOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a schema:WebPage to one or more Chunks representing segmented parts of the page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasChunkQualityScore -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasChunkQualityScore">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isChunkQualityScoreOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Establishes the relationship between a Chunk and its associated QualityScore assessment. This property enables quality evaluation at the content segment level, allowing for granular analysis of individual text portions within a webpage. Unlike page-level quality assessment, chunk-level scoring focuses on the coherence, relevance, and quality characteristics of specific content segments, supporting fine-grained content optimization and automated content analysis workflows.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasDomain -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasDomain">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Domain"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasEntityGap -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasEntityGap">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isEntityGapOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/EntityGap"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Relates a query or context to the entity gaps identified in its content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasExtractedChunk -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasExtractedChunk">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isChunkOfExtraction"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ExtractAction"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Establishes the relationship between an extraction operation and the content chunks it analyzes to retrieve specific information.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasImage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasImage">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isImageOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasIntent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasIntent">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isIntentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Intent"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a content unit to its classified intent</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasLanguage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasLanguage">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isLanguageOfImage"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Language"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the language used in the generated or translated caption</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasLink -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasLink">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isLinkOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/LinkGroup"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Link"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Defines the relationship between a LinkGroup and the individual links it contains, helping to structure internal and external linking within a webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasLinkGroup -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasLinkGroup">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isLinkGroupOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/LinkGroup"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Connects a WebPage to one or more LinkGroups that organize its internal links (e.g., navigation menus, sidebar sections, related content blocks). Enables grouping of links by purpose or position on the page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasMainTopic -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasMainTopic">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isMainTopicOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Topic"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Connects the web page to its central semantic subject</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasModel -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasModel">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isModelOfImage"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Model"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Connects an image to the model used to generate its caption</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPage">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isPageOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/PageGroup"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The hasQuery property represents the relationship between a WebPage and the PageGroup class, designed to help identify in which group type, A/B testing-wise the group belongs to.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPageInDomain -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPageInDomain">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isPartOfDomain"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Domain"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Domain contains this webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasParentSegment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasParentSegment">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Points to the parent directory in the hierarchy (e.g. /blog/seo/ → /blog/)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPathRoot -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPathRoot">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isRootOfWebpage"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates which top-level segment a page belongs to</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPersona -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPersona">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isPersonaOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Persona"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Associates a webpage with a target persona, representing the intended audience based on characteristics such as interests, demographics, or behavior</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPrimaryQuery -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPrimaryQuery">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isPrimaryQueryOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Query"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>This object attribute helps us with the querying process of queries equal to certain text</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasPrompt -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasPrompt">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Prompt"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:contributors>hasPrompt links an entity (such as a Task, Agent, or Query) to a specific Prompt that guides or constrains the behavior of an Agent. It expresses the dependency on a natural language instruction or template used to initiate or shape an AI-driven action.</dc:contributors>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasQualityScore -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasQualityScore">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isQualityScoreOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links the page to its evaluation result</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasQuery -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasQuery">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isQueryOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Query"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The hasQuery property represents the relationship between a WebPage and the Query that leads users to that page. It indicates that the WebPage is relevant or has been optimized for the specified Query. This relationship is crucial for understanding SEO dynamics, as it reflects the connection between user search behavior and web content.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasSchemaMarkup -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasSchemaMarkup">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Schema"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The usesSchema property describes the relationship between a WebPage and the Schema it employs. The Schema class represents structured data, such as JSON-LD, Microdata, or RDFa, that is embedded in the webpage to provide search engines and other tools with enhanced information about the content.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasSegmentPage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasSegmentPage">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:description>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:description>
        <dc:description>Segment contains this webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasSentiment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasSentiment">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isSentimentOf"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Sentiment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a content unit to its classified sentiment</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/hasURL -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/hasURL">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/isURLOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/URL"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The hasURL property establishes a unique and reciprocal relationship between a WebPage and its corresponding URL. It asserts that each WebPage is identified by exactly one URL, and conversely, each URL uniquely identifies one WebPage. As both a functional and inverse functional property, hasURL ensures that this link is both unique and bidirectional, which is critical for accurately representing the identity and accessibility of web content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/influencedByQuery -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/influencedByQuery">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnchorText"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Query"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The influencedByQuery property defines the relationship between AnchorText and the Query that may shape or determine the choice of that anchor text. It highlights how specific search queries can influence the wording and selection of anchor texts within a WebPage, reflecting SEO strategies aimed at optimizing link relevance and search engine visibility. This property is vital for understanding the interplay between user search behavior and content creation, particularly in the context of link building and on-page SEO</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isAnalysisTargetOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isAnalysisTargetOf">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Chunk"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/WebPage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/AnalyzeAction"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasAnalysisTarget. Links content units (WebPage or Chunk) back to the AnalyzeAction instances that examine them, enabling reverse navigation from content to its analysis activities and supporting queries that identify all analysis operations performed on specific content segments.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isChunkOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isChunkOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a Chunk to the parent WebPage it belongs to, defining the document structure</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isChunkOfExtraction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isChunkOfExtraction">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/ExtractAction"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Enables navigation from content chunks to all extraction actions that have analyzed them for information retrieval.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isChunkQualityScoreOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isChunkQualityScoreOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse property of hasChunkQualityScore that links a QualityScore instance back to the specific Chunk it evaluates. This relationship enables navigation from quality assessment results to their corresponding content segments, facilitating analysis workflows that need to identify which chunk produced particular quality metrics. Essential for content optimization systems that require traceability between quality scores and their source content segments within automated SEO and content analysis pipelines.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isContainedInSegment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isContainedInSegment">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the segment that contains a web page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isDescribedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isDescribedBy">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of about. Points from an entity to the page that describes it</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isEntityGapOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isEntityGapOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/EntityGap"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Query"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links an entity gap to the query or analysis context it belongs to</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isImageOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isImageOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasImage; links an image back to its source page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isIntentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isIntentOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Intent"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Chunk"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Query"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/WebPage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse: Links intent to the content units it classifies</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isLanguageOfImage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isLanguageOfImage">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Language"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasLanguage; returns images captioned in the given language</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isLinkGroupOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isLinkGroupOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/LinkGroup"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Defines the relationship between a LinkGroup and the WebPage it belongs to, helping structure internal linking and improve content organization</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isLinkOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isLinkOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse property of seovoc:hasLink, linking a link back to its parent LinkGroup</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isMainTopicOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isMainTopicOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Topic"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasMainTopic; links a topic to the pages where it is featured</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isModelOfImage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isModelOfImage">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Model"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasModel; identifies images a model has been used for</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isPageOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isPageOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/PageGroup"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasPage. Indicates which page group a web page belongs to</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isPartOfDirectorySegment -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isPartOfDirectorySegment">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the directory segment of the page’s URL</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isPartOfDomain -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isPartOfDomain">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Domain"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the domain or subdomain to which the page belongs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isPersonaOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isPersonaOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Persona"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasPersona. Links a persona to the page it is associated with</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isPrimaryQueryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isPrimaryQueryOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Defines the relationship between a search query (seovoc:Query) and the webpage (seovoc:WebPage) for which it serves as the main or most relevant query</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isQualityScoreOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isQualityScoreOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of seovoc:hasQualityScore. Links a quality score instance back to the web page it evaluates</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isQueryOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isQueryOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasQuery. Indicates which web page a query relates to</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isRootOfWebpage -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isRootOfWebpage">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates a root segment responsible for a page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isSentimentOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isSentimentOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Sentiment"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Chunk"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/Query"/>
                    <rdf:Description rdf:about="https://w3id.org/seovoc/WebPage"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Relates the sentiment to the piece of content to which the sentiment applies</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isURLOf -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isURLOf">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/URL"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of hasURL. Connects a URL to the web page it represents</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/isUsedByAgent -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/isUsedByAgent">
        <owl:inverseOf rdf:resource="https://w3id.org/seovoc/usesTool"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Tool"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Agent"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Inverse of usesTool. Links a Tool back to the Agent(s) that utilize it.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/issuedBy -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/issuedBy">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Prompt"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Employee"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>issuedBy links a Prompt to the Employee who authored, formulated, or issued it. It captures the origin and authorship of instructional input, supporting traceability, collaboration, and evaluation in SEO workflows.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/link -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/link">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Link"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The link property represents the relationship between a WebPage and the various Links contained within it. Each instance of the Link class corresponds to a hyperlink found on the WebPage, capturing both internal and external connections. This property is essential for modeling the structure of a webpage, understanding the flow of traffic between pages, and analyzing link-based SEO strategies, as it reflects the network of connections that can influence search engine rankings and user navigation.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/mentions -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/mentions">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://schema.org/Thing"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Each webpage has an entity of type Thing: Person, Location, LocalBusiness etc.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/seovoc/usesTool -->

    <owl:ObjectProperty rdf:about="https://w3id.org/seovoc/usesTool">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Agent"/>
        <rdfs:range rdf:resource="https://w3id.org/seovoc/Tool"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links an Agent to the Tool(s) they employ to perform analysis actions. This relationship captures the instrumental means by which agents execute their analytical tasks.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2002/07/owl#topDataProperty -->

    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topDataProperty">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:description>Establishes the relationship between a Chunk and its associated QualityScore assessment. This property enables quality evaluation at the content segment level, allowing for granular analysis of individual text portions within a webpage. Unlike page-level quality assessment, chunk-level scoring focuses on the coherence, relevance, and quality characteristics of specific content segments, supporting fine-grained content optimization and automated content analysis workflows.</dc:description>
    </rdf:Description>
    


    <!-- https://w3id.org/seovoc/ageRange -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/ageRange">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Persona"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents the age range of a persona, typically expressed as a string (e.g., &apos;18-25&apos;). This property helps categorize personas by their approximate age groups for tailored strategies or content.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/agentID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/agentID">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Unique identifier for the agent</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/agentType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/agentType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/type"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the type of agent (human, AI, bot, system...)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/agentVersion -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/agentVersion">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Agent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the version number for the agent</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/aiGeneratedCaption -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/aiGeneratedCaption">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Caption generated by an AI model describing the image content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/aiGeneratedFileName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/aiGeneratedFileName">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>SEO-optimized file name generated by an AI mode</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/analysisMethod -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/analysisMethod">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnalyzeAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Method used for performing the analysis. Examples: &apos;automated&apos; for tool-based analysis without human intervention, &apos;manual&apos; for human-conducted evaluation, &apos;hybrid&apos; for combined automated and manual review, &apos;ai-based&apos; for LLM or machine learning analysis, &apos;tool-based&apos; for analysis using specific software tools like Lighthouse or PageSpeed Insight.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/analysisScope -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/analysisScope">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnalyzeAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Scope or granularity of the analysis. Examples: &apos;page&apos; for single webpage analysis, &apos;site&apos; for entire website evaluation, &apos;domain&apos; for domain-wide assessment including subdomains, &apos;element&apos; for specific HTML elements or components, &apos;resource&apos; for individual files like CSS or JavaScript, &apos;chunk&apos; for content segments or text blocks within a page.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/analysisType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/analysisType">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnalyzeAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Type of analysis to perform. Examples: &apos;content&apos; for readability and quality assessment, &apos;performance&apos; for speed and Core Web Vitals, &apos;accessibility&apos; for WCAG compliance, &apos;security&apos; for HTTPS and headers, &apos;technical-seo&apos; for meta tags and markup, &apos;usability&apos; for user experience factors, &apos;mobile&apos; for mobile-specific analysis, &apos;core-web-vitals&apos; for LCP/FID/CLS metrics.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/anchorValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/anchorValue">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/AnchorText"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The text of the anchor tied to the link itself</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The average ranking positon that the page has for a given time period on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition28Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition28Days">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position for 28 Days on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition28DaysTo3MonthsTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition28DaysTo3MonthsTrend">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position trend for 28Days to 3Months on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition3Months -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition3Months">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position for 3 Months on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition7DaysTo28DaysTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition7DaysTo28DaysTrend">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position trend of 7Days to 28Days on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePosition7DaysTo3MonthsTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePosition7DaysTo3MonthsTrend">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position trend of 7Days to 3Months on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/averagePositon7Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/averagePositon7Days">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The ranking position for 7 Days on SERPs</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/bodyText -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/bodyText">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/text"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description rdf:resource="https://w3id.org/seovoc/"/>
        <dc:description>Main textual body content of the page</dc:description>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/bounceRate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/bounceRate">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The bounce rate, originally coming as a metric from Universal Google Analytics. Needs to be accordingly modeled for GA4</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/captionQualityScore -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/captionQualityScore">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/ImageObject"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Numeric score indicating the quality of the AI-generated caption</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/changeFrequency -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/changeFrequency">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Describes how often the page is expected to change (e.g., &quot;daily&quot;, &quot;weekly&quot;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/chunkID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/chunkID">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A unique string identifier for distinguishing individual resources, such as chunks</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/chunkPosition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/chunkPosition">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The order of the chunk on the webpage, starting from 1 for the first chunk. Useful for reconstructing the document from its parts or presenting chunks in context</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/position"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/chunkSetName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/chunkSetName">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The name of the set of chunks (e.g., &quot;Introduction&quot;, &quot;Body&quot;, &quot;Summary&quot;). Useful for organizing chunks into meaningful groups</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/chunkStrategy -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/chunkStrategy">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Describes the chunking strategy applied to split the document (e.g., &quot;Semantic Segmentation&quot;, &quot;Fixed-Length&quot;, &quot;Sentence-based&quot;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/chunkText -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/chunkText">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/text"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>chunkText is a portion or segment of a larger body of text, typically created by dividing the text into smaller, manageable pieces for processing or embedding</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/classificationConfidence -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/classificationConfidence">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Intent"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Sentiment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Numeric score (0.0–1.0) indicating the model&apos;s confidence in its classification of intent or sentiment</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/clickDepth -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/clickDepth">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The click depth of the page itself. Example: https://wordlift.io/blog/en/seo-automation/ is on level 4 if we count the parts between //</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/clicks -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/clicks">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The average number of clicks the pages have for a given time period.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/clicks28Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/clicks28Days">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The total number of clicks the query has for a given time period of 28 Days</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">clicks28Days</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/clicks28DaysTo3MonthsTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/clicks28DaysTo3MonthsTrend">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
