        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:contributors>Main heading (&lt;h1&gt;) of the page</dc:contributors>
        <dc:identifier rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/h2 -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/h2">
