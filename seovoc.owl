        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An ID when available</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/importOrigin -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/importOrigin">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A string representing the source of data or the procedure</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Impressions of the webpage as a metric coming from Google Search Console</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions28Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions28Days">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions for a 28 months period</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">impressions28Days</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions28DaysTo3MonthsTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions28DaysTo3MonthsTrend">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions trend when you compare 28Days to 3Months</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions3Months -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions3Months">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions of the webpage for a 3 months time period</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">impressions3Months</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions7Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions7Days">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#long"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions for 7Days of the Webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">impressions7Days</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions7DaysTo28DaysTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions7DaysTo28DaysTrend">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions trend of 7Days to 28Days</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/impressions7DaysTo3MonthsTrend -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/impressions7DaysTo3MonthsTrend">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The impressions trend of 7Days to 3Months</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/incomingLinkCount -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/incomingLinkCount">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Number of other pages that link to this page (link popularity signal)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/intent -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/intent">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Intent is done on a page level, so it will be added as a data property to the Page class</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/internalLinkCount -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/internalLinkCount">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Number of links that point to the same domain as the current page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/internalPageRank -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/internalPageRank">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>PageRank score computed based on internal link structure</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/keywordOptimizationScore -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/keywordOptimizationScore">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Keyword usage and distribution score</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/keywordType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/keywordType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/type"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Primary and secondary keyword modeling are expressed through the use of the data property keywordType</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/keywords -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/keywords">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A list of keywords associated with the specific link, aiding semantic classification</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/keywords"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/label -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/label">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The label name of the identified item</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/languageCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/languageCode">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Language"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>ISO 639-1 or 639-2 code</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/languageName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/languageName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Language"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Full language name</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/languageRegion -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/languageRegion">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Language"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Regional variant (e.g., en-US)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/lastDirectory -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/lastDirectory">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The last directory in the URL path, useful for sub-clustering</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/lastModified -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/lastModified">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Timestamp of the last update to the content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/linkGroupName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/linkGroupName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/LinkGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The human-readable name of the LinkGroup, typically reflecting its function or placement on a webpage (e.g., &apos;Footer Links&apos;, &apos;Sidebar Menu&apos;, &apos;Main Navigation&apos;))</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/linkLocation -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/linkLocation">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Location of the link within the layout (e.g., nav, header, footer, body)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/linkText -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/linkText">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/text"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Text used as the anchor for the hyperlink</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/linkType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/linkType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/type"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The type of the link, with two possible values inbound and outbound (internal link coming from the same website or external link coming from an external website)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/linkgroupID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/linkgroupID">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/LinkGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A unique string identifier for distinguishing individual resources, such as link groups</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/locationName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/locationName">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/EntityGap"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates where in the content or source the entity gap was detected</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/markdownText -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/markdownText">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/text"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents a Markdown-formatted version of a webpage’s content, specifically structured for Large Language Model (LLM) processing, meant for efficient tokenization and retrieval-augmented generation (RAG) in AI applications</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/menu -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/menu">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>As a replacement for hasMenu</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/metaDescription -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/metaDescription">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/description"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The meta description of the webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/metaTitle -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/metaTitle">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The meta title of the webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/modelName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/modelName">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Human-readable identifier of the model used (e.g., “BLIP Large”)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/modelUrl -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/modelUrl">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Model"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Web-accessible URI pointing to the model, documentation, or registry entry</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/name -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/name">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The human-readable name of the LinkGroup, typically reflecting its function or placement on a webpage (e.g., &apos;Footer Links&apos;, &apos;Sidebar Menu&apos;, &apos;Main Navigation&apos;)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/name"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/noFollow -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/noFollow">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A metric to define whether the nofollow is in place (True for Yes and False for No)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/occurrences -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/occurrences">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/EntityGap"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An integer indicating how many times the missing entity appears in the analyzed data</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/pageGroupName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/pageGroupName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/PageGroup"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the name of the group in which the page belongs, A , B, C (control A, control B, test A, test ...B)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/performedAt -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/performedAt">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Action"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Timestamp indicating when the action was executed, enabling temporal tracking and audit trails within SEO workflows.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/position -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/position">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The position of an item in a series or sequence of items</dc:description>
        <skos:exactMatch rdf:resource="https://schema.org/position"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/preferredDevice -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/preferredDevice">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Persona"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents the device type a persona most commonly uses to access information or services. Examples include &apos;mobile&apos;, &apos;desktop&apos;, &apos;tablet&apos;, or &apos;smart speaker&apos;. This property helps in tailoring content and strategies to the persona&apos;s preferred platform</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/priorityScore -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/priorityScore">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Used in automated sitemap generation and crawl scheduling to prioritize the discovery and indexing of pages that are central to the website&apos;s architecture or frequently updated</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/promptDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/promptDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Prompt"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <dc:description>A date when the prompt was put into the system</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:isDefinedBy>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</rdfs:isDefinedBy>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/publishingDate -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/publishingDate">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The date where the webpage was published</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/queryCategory -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/queryCategory">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Advice</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Explanations</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Facts</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Planning</rdf:first>
                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents the broader category of a user&apos;s information-seeking query. This property classifies queries into four key categories based on their intent and expected outcome: 
        - Advice: Queries that seek recommendations, suggestions, or guidance for decision-making. 
        - Explanations: Queries aimed at understanding concepts, reasoning, or detailed clarifications.
        - Facts: Queries that request verifiable and objective pieces of information.
        - Planning: Queries focused on structuring activities, workflows, or determining sequential steps to achieve a goal.
These categories help in organizing user search behaviors and improving query understanding.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/queryDateCreated -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/queryDateCreated">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/date"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The date/time this keyword analytics data has been extracted and imported in the KG.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/queryType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/queryType">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/type"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:oneOf>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                        <rdf:first>Analytical</rdf:first>
                        <rdf:rest>
                            <rdf:Description>
                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                <rdf:first>Causal</rdf:first>
                                <rdf:rest>
                                    <rdf:Description>
                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                        <rdf:first>Commonsense</rdf:first>
                                        <rdf:rest>
                                            <rdf:Description>
                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                <rdf:first>Cultural</rdf:first>
                                                <rdf:rest>
                                                    <rdf:Description>
                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                        <rdf:first>Dynamic</rdf:first>
                                                        <rdf:rest>
                                                            <rdf:Description>
                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                <rdf:first>Exploratory</rdf:first>
                                                                <rdf:rest>
                                                                    <rdf:Description>
                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                        <rdf:first>Instructive</rdf:first>
                                                                        <rdf:rest>
                                                                            <rdf:Description>
                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                <rdf:first>Lifestyle</rdf:first>
                                                                                <rdf:rest>
                                                                                    <rdf:Description>
                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                        <rdf:first>Long-tail</rdf:first>
                                                                                        <rdf:rest>
                                                                                            <rdf:Description>
                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                <rdf:first>Multi-hop</rdf:first>
                                                                                                <rdf:rest>
                                                                                                    <rdf:Description>
                                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                        <rdf:first>Philosophical</rdf:first>
                                                                                                        <rdf:rest>
                                                                                                            <rdf:Description>
                                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                <rdf:first>Popular</rdf:first>
                                                                                                                <rdf:rest>
                                                                                                                    <rdf:Description>
                                                                                                                        <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                        <rdf:first>Recommendation</rdf:first>
                                                                                                                        <rdf:rest>
                                                                                                                            <rdf:Description>
                                                                                                                                <rdf:type rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#List"/>
                                                                                                                                <rdf:first>Spatio-temporal</rdf:first>
                                                                                                                                <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                                                                                                                            </rdf:Description>
                                                                                                                        </rdf:rest>
                                                                                                                    </rdf:Description>
                                                                                                                </rdf:rest>
                                                                                                            </rdf:Description>
                                                                                                        </rdf:rest>
                                                                                                    </rdf:Description>
                                                                                                </rdf:rest>
                                                                                            </rdf:Description>
                                                                                        </rdf:rest>
                                                                                    </rdf:Description>
                                                                                </rdf:rest>
                                                                            </rdf:Description>
                                                                        </rdf:rest>
                                                                    </rdf:Description>
                                                                </rdf:rest>
                                                            </rdf:Description>
                                                        </rdf:rest>
                                                    </rdf:Description>
                                                </rdf:rest>
                                            </rdf:Description>
                                        </rdf:rest>
                                    </rdf:Description>
                                </rdf:rest>
                            </rdf:Description>
                        </rdf:rest>
                    </rdf:Description>
                </owl:oneOf>
            </rdfs:Datatype>
        </rdfs:range>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Specifies the type of query a user is performing, which must belong to a predefined set of query categories. These categories include: Popular, Long-tail, Dynamic, Multi-hop, Analytical, Commonsense, Causal, Exploratory, Instructive, Recommendation, Spatio-temporal, Lifestyle, Cultural, and Philosophical.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/readabilityGradeLevel -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/readabilityGradeLevel">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An ordinal estimate (e.g., U.S. school grade level)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/readabilityScore -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/readabilityScore">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/QualityScore"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Readability score for the webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/role -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/role">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Persona"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A specific function, position, or responsibility associated with a persona within a given context. This class defines how a persona interacts with a system, organization, or content, influencing their goals and actions.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/rootSegmentFlag -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/rootSegmentFlag">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates if this is the top-level segment in the site&apos;s hierarchy</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/schemaValue -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/schemaValue">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Schema"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The schema value itself of the publicly available schema on the webpage</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/score -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/score">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>General numeric quality or performance score</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/score28Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/score28Days">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The overall score for the query for 28Days time period</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">score28Days</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/score3Months -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/score3Months">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The overall score for the query for 3Months time period</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">score3Months</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/score7Days -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/score7Days">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Query"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description xml:lang="en">A calculated score ranging from 0.0 to 1.0 to determine the keywords with potential.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">score7Days </rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/searchStage -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/searchStage">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Intent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Funnel-stage classification (e.g., INFORMATIONAL, COMMERCIAL, TRANSACTIONAL)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/segmentDepth -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/segmentDepth">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/DirectorySegment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Indicates the depth level of a directory segment within a URL path hierarchy</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/seoScore -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/seoScore">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/score"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#double"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Measures how optimized a page is for SEO or how good the on-page SEO score is</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/serpPosition -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/serpPosition">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/position"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/EntityGap"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An integer indicating the search engine results page (SERP) position where the entity gap was observed</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/slugNgram -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/slugNgram">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Semantic content clues derived from n-grams in the slug (for ML segmentation)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/sourceCode -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/sourceCode">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The raw HTML of the webpage itself.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/start -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/start">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The start offset of the chunk in the text, expressed as character or token position</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/status -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/status">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The HTTP status (response code) of the Webpage itself</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/text -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/text">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The plain text content of the chunk, stripped of formatting, used for embeddings, analysis, or display in NLP applications</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/text"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/thingLabel -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/thingLabel">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/label"/>
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The name of the Thing item</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/thumbnailUrl -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/thumbnailUrl">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A URL pointing to a thumbnail image for the link, useful for visually rich links</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/thumbnailUrl"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/title -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/title">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The actual title of the webpage itself</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="https://schema.org/title"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/tokenCount -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/tokenCount">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Chunk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The number of tokens in the chunk, typically counted using a tokenizer compatible with the embedding model or LLM processing the content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/toolName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/toolName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Human-readable identifier of the tool (e.g., &quot;Screaming Frog&quot;, &quot;Lighthouse&quot;, &quot;Custom Crawler&quot;).</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/toolType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/toolType">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Category or classification of the tool (e.g., &quot;crawler&quot;, &quot;analyzer&quot;, &quot;validator&quot;, &quot;performance-monitor&quot;).</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/toolUrl -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/toolUrl">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Tool"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Web-accessible URI pointing to the tool&apos;s homepage, documentation, or registry entry.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/topicID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/topicID">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Topic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Unique topic identifier</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/topicName -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/topicName">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/name"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Topic"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Human-readable topic name</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/totalLinkCount -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/totalLinkCount">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Total number of hyperlinks found on the page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/type -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/type">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/urlSlug -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/urlSlug">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Links a web page to its domain or subdomain</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/value -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/value">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/URL"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The URL value of the Webpage itself</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/versionID -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/versionID">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/seovoc/identifier"/>
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An integer identifier representing the current version of a web page</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/weight -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/weight">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Link"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <dc:contributors rdf:resource="https://w3id.org/seovoc/"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The weight of the link, useful for ranking or tag clouds</dc:description>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://schema.org/Action -->

    <owl:Class rdf:about="http://schema.org/Action">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The Action class from Schema.org</dc:description>
    </owl:Class>
    


    <!-- http://schema.org/Person -->

    <owl:Class rdf:about="http://schema.org/Person">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:identifier rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:isDefinedBy>The Person class from Schema.org</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://schema.org/Thing -->

    <owl:Class rdf:about="http://schema.org/Thing">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The Thing class from Schema.org</dc:description>
        <rdfs:comment>should i use the URI to define exact match or create schema -alike classes?</rdfs:comment>
    </owl:Class>
    


    <!-- http://schema.org/WebPage -->

    <owl:Class rdf:about="http://schema.org/WebPage">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>The WebPage class from Schema.org</dc:description>
    </owl:Class>
    


    <!-- http://www.w3.org/2002/07/owl#Thing -->

    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#Thing">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A Thing that may have a schema:url, hence may have analytics data bound to it.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label>Thing</rdfs:label>
        <skos:exactMatch rdf:resource="http://schema.org/Thing"/>
    </rdf:Description>
    


    <!-- https://w3id.org/seovoc/Action -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Action">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="http://schema.org/Action"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Agent -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Agent">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>An Agent is any autonomous or semi-autonomous system—such as an AI model, human user, or software tool that performs actions on SEO-relevant entities (e.g. generating content, classifying queries, linking pages). Agents are responsible for producing, transforming, or evaluating outputs within SEO workflows.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/AnalyzeAction -->

    <owl:Class rdf:about="https://w3id.org/seovoc/AnalyzeAction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seovoc/Action"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>General-purpose analysis action that can evaluate any aspect of web resources including content quality, performance, accessibility, security, technical SEO, and other measurable characteristics.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/AnchorText -->

    <owl:Class rdf:about="https://w3id.org/seovoc/AnchorText">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A class representing the anchor text of a hyperlink, which is the clickable text displayed for a link on a webpage. This class captures the textual content used to describe the target of the link, often influencing search engine optimization (SEO) and user experience. The AnchorText class is important for understanding how links are represented in the context of a webpage and how they contribute to the navigation and relevance of the content</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Chunk -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Chunk">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Defines a Chunk, a self-contained section of a schema:WebPage used for vector search and structured representation</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/DirectorySegment -->

    <owl:Class rdf:about="https://w3id.org/seovoc/DirectorySegment">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seovoc/WebPage"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A top-level or intermediate directory segment in a URL path (e.g., /products/)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Domain -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Domain">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A domain or subdomain (e.g., example.com, blog.example.com)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Employee -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Employee">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seovoc/Person"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:identifier rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:isDefinedBy>A type of Person, defined in SEOntology</rdfs:isDefinedBy>
        <skos:exactMatch rdf:resource="http://schema.org/Person"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/EntityGap -->

    <owl:Class rdf:about="https://w3id.org/seovoc/EntityGap">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents a relevant but missing entity that should be added to content to enhance semantic coverage and SEO performance</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/ExtractAction -->

    <owl:Class rdf:about="https://w3id.org/seovoc/ExtractAction">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seovoc/Action"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents systematic extraction of structured or unstructured information from web content, including entity extraction, fact retrieval, data mining, and relationship identification. Distinct from summarization by focusing on specific information retrieval rather than content condensation.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/ImageObject -->

    <owl:Class rdf:about="https://w3id.org/seovoc/ImageObject">
        <skos:exactMatch rdf:resource="https://schema.org/ImageObject"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Intent -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Intent">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A reusable conceptual entity representing the purpose of a query or content chunk</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Language -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Language">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Natural languages such as Spanish, Tamil, Hindi, English, etc</dc:description>
        <skos:exactMatch rdf:resource="https://schema.org/Language"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Link -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Link">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A class representing a hyperlink found on a webpage. This class captures the attributes of a link and its type, such as whether the link is internal (pointing to the same domain) or external (pointing to a different domain). The Link class is crucial for understanding the structure and navigation of a website, as well as for analyzing the relationships between different web resources in the context of SEO and web development.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/LinkGroup -->

    <owl:Class rdf:about="https://w3id.org/seovoc/LinkGroup">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A collection of related links within a webpage, typically grouped by placement or function, such as navigation menus, footers, or sidebars. It helps structure internal linking and improves discoverability.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Model -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Model">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A generic ML model class for provenance traceabilit</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/PageGroup -->

    <owl:Class rdf:about="https://w3id.org/seovoc/PageGroup">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A class representing in which A/B testing group does the page belong: control A, control B, test A, test B and so on.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Person -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Person">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:identifier rdf:resource="https://w3id.org/seovoc/"/>
        <skos:exactMatch rdf:resource="http://schema.org/Person"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Persona -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Persona">
        <rdfs:subClassOf rdf:resource="https://w3id.org/seovoc/Person"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A representation of a specific audience or user group defined by key characteristics, including their role, brand association, age range, gender, location, problems they aim to solve, and preferred devices. This class is used to tailor content or strategies to meet the needs and expectations of these target personas.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Prompt -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Prompt">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents a structured natural language input used to guide AI models in generating or transforming SEO-relevant content. It serves as a semantic instruction or query that elicits specific types of responses from generative or analytical AI systems, including but not limited to content generation, classification, rewriting, summarization, and entity extraction.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/QualityScore -->

    <owl:Class rdf:about="https://w3id.org/seovoc/QualityScore">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Represents an overall content quality evaluation</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Query -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Query">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description xml:lang="en">A class representing a search query. Instances of this class encapsulate the parameters, conditions, and terms submitted to a search engine by users or systems. This class is fundamental to modeling and analyzing search behavior, including keyword selection, query intent, and search patterns in the context of SEO.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">Query</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Schema -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Schema">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>This class represents schema markup, a form of structured data that defines the semantic relationships between entities on a webpage. Schema markup is used to enhance the understanding of web content by search engines and other applications, facilitating better indexing, richer search results, and improved interoperability across different systems. This class provides a framework for describing the types, properties, and relationships that constitute schema markup, enabling consistent and meaningful representation of web content.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Sentiment -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Sentiment">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A conceptual entity representing the emotional polarity (e.g., positive, negative) of a query or content chunk</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Tool -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Tool">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A software application, platform, or instrument used to perform SEO analysis, content evaluation, or web assessment. Tools are utilized by Agents to execute specific analysis tasks and generate measurable outputs.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/Topic -->

    <owl:Class rdf:about="https://w3id.org/seovoc/Topic">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>A dedicated class for modeling the subject or main theme of a web page or content segment. It can represent an entity, theme, or abstract concept the content is centered on</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/URL -->

    <owl:Class rdf:about="https://w3id.org/seovoc/URL">
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>This class represents a unique URL that identifies a specific webpage. It is intended to serve as a stable and unambiguous reference to web content, ensuring consistent access to the webpage across various systems and applications. The URL should be a valid and well-formed HTTP or HTTPS address, uniquely pointing to a resource on the World Wide Web. NOT equivalent to schema.org&apos;s URL.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:Class>
    


    <!-- https://w3id.org/seovoc/WebPage -->

    <owl:Class rdf:about="https://w3id.org/seovoc/WebPage">
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description xml:lang="en">A web page. Every web page is implicitly assumed to be declared to be of type WebPage, so the various properties about that webpage, such as breadcrumb may be used. We recommend explicit declaration if these properties are specified, but if they are found outside of an itemscope, they will be assumed to be about the page.</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
        <rdfs:label xml:lang="en">WebPage</rdfs:label>
        <skos:exactMatch rdf:resource="http://schema.org/WebPage"/>
    </owl:Class>
    


