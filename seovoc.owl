        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Full relative URL path of the segment (e.g. /blog/seo/)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/googleCategory -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/googleCategory">
        <rdfs:domain rdf:resource="https://w3id.org/seovoc/Intent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <dc:contributors>Andrea Volpini, David Riccitelli, Emilija Gjorgjevska, Milos Jovanovik</dc:contributors>
        <dc:description>Label from Google&apos;s categorization (e.g., SHORT_FACT, REASON, DEFINITION)</dc:description>
        <rdfs:isDefinedBy rdf:resource="https://w3id.org/seovoc/"/>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/seovoc/groupType -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/seovoc/groupType">
